# ┌──────────────────────────────────────────────────────────────┐
# │  smaRT Backend — Production Environment (Generated)         │
# │  Managed by Ansible — DO NOT EDIT MANUALLY ON SERVER       │
# └──────────────────────────────────────────────────────────────┘

APP_NAME=smaRT
APP_ENV=production
APP_KEY={{ vault_app_key }}
APP_DEBUG=false
APP_URL={{ app_url | default('http://' + ansible_host) }}

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE={{ vault_db_database }}
DB_USERNAME={{ vault_db_username }}
DB_PASSWORD={{ vault_db_password }}
DB_ROOT_PASSWORD={{ vault_db_root_password }}

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN={{ session_domain | default('null') }}

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER={{ mail_mailer | default('log') }}
MAIL_HOST={{ mail_host | default('127.0.0.1') }}
MAIL_PORT={{ mail_port | default('2525') }}
MAIL_USERNAME={{ mail_username | default('null') }}
MAIL_PASSWORD={{ mail_password | default('null') }}
MAIL_FROM_ADDRESS="{{ mail_from_address | default('noreply@example.com') }}"
MAIL_FROM_NAME="${APP_NAME}"

JWT_SECRET={{ vault_jwt_secret }}
JWT_ALGO=HS256

FIREBASE_CREDENTIALS=storage/firebase-credentials.json

APP_PORT={{ app_port | default('80') }}
