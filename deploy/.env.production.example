# ┌──────────────────────────────────────────────────────────────┐
# │  smaRT Backend — Production Environment Variables           │
# │                                                              │
# │  Copy this file to .env.production and fill in real values. │
# │  NEVER commit .env.production to version control!           │
# └──────────────────────────────────────────────────────────────┘

# ── App Configuration ────────────────────────────────────────────
APP_NAME=smaRT
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://your-domain.com

# ── Database ─────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=smart_backend
DB_USERNAME=smart_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# ── Docker ───────────────────────────────────────────────────────
APP_PORT=80

# ── Logging ──────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Session & Cache ──────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=your-domain.com
BCRYPT_ROUNDS=12

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_GENERATE_NEW_SECRET
JWT_ALGO=HS256

# ── Firebase ─────────────────────────────────────────────────────
FIREBASE_CREDENTIALS=storage/firebase-credentials.json

# ── Mail (Optional) ─────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"
